{
  "name": "@cafecode/desktop",
  "version": "0.1.1",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "tsdown",
    "start": "node scripts/start-electron.mjs",
    "start:debug": "node scripts/start-electron.mjs --cafe-debug",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "smoke-test": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@cafecode/contracts": "workspace:*",
    "@cafecode/shared": "workspace:*",
    "@effect/platform-node": "catalog:",
    "effect": "catalog:",
    "electron": "42.2.0",
    "electron-updater": "^6.6.2",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "productName": "Cafe Code (Alpha)"
}
