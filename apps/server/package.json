{
  "name": "@cafeai/cafe-code",
  "version": "0.1.1",
  "description": "A minimal AI chat harness for coding agents.",
  "keywords": [
    "agent",
    "ai",
    "claude",
    "codex",
    "coding-agent",
    "desktop",
    "electron"
  ],
  "homepage": "https://github.com/cafeai/cafe-code#readme",
  "bugs": {
    "url": "https://github.com/cafeai/cafe-code/issues"
  },
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cafeai/cafe-code.git",
    "directory": "apps/server"
  },
  "bin": {
    "cafe-code": "dist/launcher.mjs",
    "cafe-code-server": "dist/bin.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "node --watch src/bin.ts",
    "build": "node scripts/cli.ts build",
    "build:bundle": "tsdown",
    "prepack": "node scripts/cli.ts assert-publish-prepared",
    "prepublishOnly": "node scripts/cli.ts assert-publish-prepared",
    "start": "node dist/bin.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e:provider-pipeline": "vitest run --config vitest.e2e.config.ts integration/providerPipelineLiveness.e2e.test.ts",
    "test:e2e:provider-daemon": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.216",
    "@anthropic-ai/sdk": "^0.98.0",
    "@effect/platform-node": "catalog:",
    "@effect/platform-node-shared": "catalog:",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.17.18",
    "@pierre/diffs": "catalog:",
    "@types/web-push": "^3.6.4",
    "effect": "catalog:",
    "electron": "42.2.0",
    "electron-updater": "^6.6.2",
    "node-pty": "^1.1.0",
    "web-push": "^3.6.7",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cafecode/contracts": "workspace:*",
    "@cafecode/shared": "workspace:*",
    "@cafecode/web": "workspace:*",
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "effect-codex-app-server": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^22.19 || ^23.11 || >=24.10"
  }
}
