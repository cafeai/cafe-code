{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "HOST",
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "CAFE_CODE_LOG_WS_EVENTS",
    "CAFE_CODE_MODE",
    "CAFE_CODE_PORT",
    "CAFE_CODE_NO_BROWSER",
    "CAFE_CODE_HOME",
    "CAFE_CODE_AUTH_TOKEN",
    "CAFE_CODE_DESKTOP_DEV",
    "CAFE_CODE_DESKTOP_WS_URL",
    "CAFE_CODE_TRACE_MIN_LEVEL",
    "CAFE_CODE_TRACE_TIMING_ENABLED",
    "CAFE_CODE_TRACE_FILE",
    "CAFE_CODE_TRACE_MAX_BYTES",
    "CAFE_CODE_TRACE_MAX_FILES",
    "CAFE_CODE_TRACE_BATCH_WINDOW_MS",
    "CAFE_CODE_OTLP_TRACES_URL",
    "CAFE_CODE_OTLP_METRICS_URL",
    "CAFE_CODE_OTLP_EXPORT_INTERVAL_MS",
    "CAFE_CODE_OTLP_SERVICE_NAME",
    "APP_VERSION"
  ],
  "globalPassThroughEnv": [
    "CAFE_CODE_LINUX_PASSWORD_STORE",
    "DBUS_SESSION_BUS_ADDRESS",
    "DESKTOP_SESSION",
    "DISPLAY",
    "KDE_FULL_SESSION",
    "KDE_SESSION_VERSION",
    "PATHEXT",
    "WAYLAND_DISPLAY",
    "XDG_CURRENT_DESKTOP",
    "XDG_RUNTIME_DIR",
    "XDG_SESSION_DESKTOP",
    "XDG_SESSION_TYPE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["@cafecode/contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
