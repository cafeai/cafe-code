{
  "name": "@cafecode/monorepo",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "workspaces": {
    "packages": [
      "apps/*",
      "oxlint-plugin-cafecode",
      "packages/*",
      "scripts"
    ],
    "catalog": {
      "effect": "4.0.0-beta.59",
      "@effect/atom-react": "4.0.0-beta.59",
      "@effect/openapi-generator": "4.0.0-beta.59",
      "@effect/platform-bun": "4.0.0-beta.59",
      "@effect/platform-node": "4.0.0-beta.59",
      "@effect/platform-node-shared": "4.0.0-beta.59",
      "@effect/sql-sqlite-bun": "4.0.0-beta.59",
      "@effect/vitest": "4.0.0-beta.59",
      "@effect/language-service": "0.84.2",
      "@pierre/diffs": "1.1.20",
      "@types/bun": "^1.3.11",
      "@types/node": "^24.10.13",
      "tsdown": "^0.22.0",
      "typescript": "^5.7.3",
      "vitest": "^4.1.10"
    }
  },
  "type": "module",
  "scripts": {
    "prepare": "effect-language-service patch",
    "dev": "node scripts/dev-runner.ts dev",
    "dev:server": "node scripts/dev-runner.ts dev:server",
    "dev:web": "node scripts/dev-runner.ts dev:web",
    "dev:desktop": "node scripts/dev-runner.ts dev:desktop",
    "start": "turbo run start --filter=@cafeai/cafe-code",
    "start:desktop": "turbo run start --filter=@cafecode/desktop",
    "start:desktop:debug": "turbo run start:debug --filter=@cafecode/desktop",
    "restart:desktop": "node scripts/restart-cafe-code.ts",
    "killall": "node apps/server/src/bin.ts killall",
    "profile:desktop-startup": "node scripts/profile-desktop-startup.ts",
    "start:mock-update-server": "node scripts/mock-update-server.ts",
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=@cafecode/desktop --filter=@cafeai/cafe-code",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "turbo run test",
    "test:desktop-smoke": "turbo run smoke-test --filter=@cafecode/desktop",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build:contracts": "turbo run build --filter=@cafecode/contracts",
    "dist:desktop:artifact": "node scripts/build-desktop-artifact.ts",
    "dist:desktop:dmg": "node scripts/build-desktop-artifact.ts --platform mac --target dmg",
    "dist:desktop:dmg:arm64": "node scripts/build-desktop-artifact.ts --platform mac --target dmg --arch arm64",
    "dist:desktop:dmg:x64": "node scripts/build-desktop-artifact.ts --platform mac --target dmg --arch x64",
    "dist:desktop:linux": "node scripts/build-desktop-artifact.ts --platform linux --target AppImage --arch x64",
    "dist:desktop:win": "node scripts/build-desktop-artifact.ts --platform win --target nsis",
    "dist:desktop:win:arm64": "node scripts/build-desktop-artifact.ts --platform win --target nsis --arch arm64",
    "dist:desktop:win:x64": "node scripts/build-desktop-artifact.ts --platform win --target nsis --arch x64",
    "dist:arch:local": "node scripts/build-arch-package.ts",
    "release:smoke": "node scripts/release-smoke.ts",
    "db:compact-activity-payloads": "node scripts/compact-activity-payloads.ts",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist apps/*/dist-electron packages/*/dist .turbo apps/*/.turbo packages/*/.turbo",
    "sync:vscode-icons": "node scripts/sync-vscode-icons.mjs"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@oxlint/plugins": "^1.63.0",
    "@types/node": "catalog:",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.63.0",
    "turbo": "^2.9.14",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "overrides": {
    "@effect/atom-react": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/platform-node-shared": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@effect/vitest": "catalog:",
    "defu": "^6.1.7",
    "effect": "catalog:",
    "fast-uri": "^3.1.2",
    "hono": "^4.12.25",
    "ip-address": "^10.2.0",
    "js-yaml": "^4.2.0",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "qs": "^6.15.2",
    "undici": "^8.5.0",
    "uuid": "^13.0.1",
    "vite": "^8.0.16",
    "ws": "^8.21.0",
    "yauzl": "3.3.1"
  },
  "engines": {
    "bun": "^1.3.11",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.11",
  "msw": {
    "workerDirectory": [
      "apps/web/public"
    ]
  },
  "patchedDependencies": {
    "effect@4.0.0-beta.59": "patches/effect@4.0.0-beta.59.patch"
  },
  "trustedDependencies": [
    "node-pty",
    "electron"
  ]
}
